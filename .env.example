# === BANCO DE DADOS ===
DATABASE_URL="postgresql://usuario:senha@localhost:5432/plataforma_agendamento"

# === JWT ===
# ATENÇÃO: Gere uma chave forte com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="mude-esta-chave-em-producao-para-uma-chave-aleatoria-segura"
JWT_EXPIRES_IN="7d"

# === MENSAGERIA ===
# Provedor padrao: EVOLUTION | META | TELEGRAM
PROVEDOR_MENSAGERIA_PADRAO="EVOLUTION"

# === EVOLUTION GO (WHATSAPP API - OPEN SOURCE) ===
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="evo-api-key-agendamento"
EVOLUTION_INSTANCE_NAME="agendamento-bot"
EVOLUTION_WEBHOOK_URL="http://localhost:3000/webhook/evolution"

# === META WHATSAPP CLOUD API (OFICIAL) ===
META_ACCESS_TOKEN="seu-access-token-meta"
META_PHONE_NUMBER_ID="seu-phone-number-id"
META_BUSINESS_ACCOUNT_ID="seu-business-account-id"
META_VERIFY_TOKEN="seu-verify-token"
META_WEBHOOK_URL="http://localhost:3000/webhook/meta"

# === TELEGRAM BOT ===
TELEGRAM_BOT_TOKEN="seu-bot-token"
TELEGRAM_WEBHOOK_URL="http://localhost:3000/webhook/telegram"

# === WHATSAPP ADMIN ===
WHATSAPP_ADMIN_NUMBER="5511999999999"

# === ASAAS (PAGAMENTOS PIX) ===
ASAAS_API_KEY="seu-access-token-asaas"
ASAAS_API_URL="" # Deixe vazio para usar URL padrão (sandbox/producao)
ASAAS_SANDBOX="true"  # true para sandbox, false para producao
# Token secreto para validar webhooks do Asaas (gere um token aleatório)
ASAAS_WEBHOOK_TOKEN=""

# === REDIS (FILA DE TAREFAS) ===
REDIS_URL="redis://localhost:6379"

# === SERVER ===
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# === SIGNUP (SEGURANÇA) ===
# Chave secreta necessária para criar novos tenants. Se vazia, qualquer um pode criar conta.
# Em produção, defina uma chave forte e compartilhe apenas com administradores.
SIGNUP_SECRET_KEY=""
# Desabilita completamente a criação de novas contas
DISABLE_SIGNUP="false"

# === HORÁRIOS ===
TEMPO_BLOQUEIO_PROVISORIO_MINUTOS=15
TEMPO_EXPIRACAO_PIX_MINUTOS=15
HORAS_ANTECEDENCIA_CANCELAMENTO=2
PRAZO_EXPIRACAO_CREDITO_DIAS=365
