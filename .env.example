# === BANCO DE DADOS ===
DATABASE_URL="postgresql://usuario:senha@localhost:5432/plataforma_agendamento"

# === JWT ===
JWT_SECRET="seu-jwt-secret-aqui-mude-em-producao"
JWT_EXPIRES_IN="7d"

# === EVOLUTION GO (WHATSAPP API) ===
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="evo-api-key-agendamento"
EVOLUTION_INSTANCE_NAME="agendamento-bot"
EVOLUTION_WEBHOOK_URL="http://localhost:3000/webhook/whatsapp"

# === WHATSAPP ADMIN ===
WHATSAPP_ADMIN_NUMBER="5511999999999"

# === ASAAS (PAGAMENTOS PIX) ===
ASAAS_API_KEY="seu-access-token-asaas"
ASAAS_API_URL="" # Deixe vazio para usar URL padrão (sandbox/producao)
ASAAS_SANDBOX="true"  # true para sandbox, false para producao

# === REDIS (FILA DE TAREFAS) ===
REDIS_URL="redis://localhost:6379"

# === SERVER ===
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# === HORÁRIOS ===
TEMPO_BLOQUEIO_PROVISORIO_MINUTOS=15
TEMPO_EXPIRACAO_PIX_MINUTOS=15
HORAS_ANTECEDENCIA_CANCELAMENTO=2
PRAZO_EXPIRACAO_CREDITO_DIAS=365
