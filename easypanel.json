{
  "name": "Plataforma Agendamento",
  "description": "Sistema de agendamento para salão & barbearia com WhatsApp e PIX",
  "type": "docker-compose",
  "composeFile": "docker-compose.prod.yml",
  "env": {
    "DOMAIN": {
      "label": "Domínio principal",
      "description": "Domínio onde o sistema será acessado (ex: agendamento.meusalao.com.br)",
      "required": true
    },
    "JWT_SECRET": {
      "label": "JWT Secret",
      "description": "Chave secreta para autenticação JWT",
      "required": true,
      "type": "password"
    },
    "POSTGRES_PASSWORD": {
      "label": "Senha PostgreSQL",
      "description": "Senha do banco de dados principal",
      "required": true,
      "type": "password"
    },
    "EVOLUTION_API_KEY": {
      "label": "API Key Evolution",
      "description": "Chave de API do Evolution WhatsApp",
      "required": true,
      "type": "password"
    },
    "WHATSAPP_ADMIN_NUMBER": {
      "label": "WhatsApp Admin",
      "description": "Número do administrador para notificações (formato: 5511999999999)",
      "required": false
    },
    "ASAAS_API_KEY": {
      "label": "API Key Asaas",
      "description": "Chave de API do Asaas para pagamentos PIX",
      "required": false,
      "type": "password"
    },
    "ASAAS_SANDBOX": {
      "label": "Asaas Sandbox",
      "description": "Usar ambiente sandbox do Asaas (true/false)",
      "required": false,
      "value": "true"
    },
    "IMAGE_REPOSITORY": {
      "label": "Repositório GHCR",
      "description": "Caminho owner/repository usado nas imagens publicadas (ex: cezaralfredo/plataforma_agendamento)",
      "required": true,
      "value": "cezaralfredo/plataforma_agendamento"
    },
    "IMAGE_TAG": {
      "label": "Tag da imagem",
      "description": "Tag Docker publicada no GHCR",
      "required": false,
      "value": "latest"
    }
  },
  "services": {
    "postgres": {
      "type": "postgresql",
      "version": "16",
      "volumes": ["postgres_data"]
    },
    "redis": {
      "type": "redis",
      "version": "7"
    },
    "evolution-postgres": {
      "type": "postgresql",
      "version": "16",
      "volumes": ["evolution_postgres_data"]
    },
    "evolution": {
      "type": "docker",
      "image": "evoapicloud/evolution-api:latest",
      "ports": ["8080"]
    },
    "api": {
      "type": "docker",
      "image": "ghcr.io/cezaralfredo/plataforma_agendamento-api:latest",
      "ports": ["3000"]
    },
    "web": {
      "type": "docker",
      "image": "ghcr.io/cezaralfredo/plataforma_agendamento-web:latest",
      "ports": ["80"]
    }
  }
}
