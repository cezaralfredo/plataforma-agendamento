{
  "name": "Plataforma Agendamento",
  "description": "Sistema de agendamento para salão & barbearia com WhatsApp e PIX",
  "type": "docker-compose",
  "composeFile": "docker-compose.prod.yml",
  "env": {
    "DOMAIN": {
      "label": "Domínio principal",
      "description": "Domínio onde o sistema será acessado (ex: agendamento.meusalao.com.br)",
      "required": true
    },
    "JWT_SECRET": {
      "label": "JWT Secret",
      "description": "Chave secreta para autenticação JWT",
      "required": true,
      "type": "password"
    },
    "POSTGRES_PASSWORD": {
      "label": "Senha PostgreSQL",
      "description": "Senha do banco de dados principal",
      "required": true,
      "type": "password"
    },
    "EVOLUTION_API_KEY": {
      "label": "API Key Evolution",
      "description": "Chave de API do Evolution WhatsApp",
      "required": true,
      "type": "password"
    },
    "WHATSAPP_ADMIN_NUMBER": {
      "label": "WhatsApp Admin",
      "description": "Número do administrador para notificações (formato: 5511999999999)",
      "required": false
    },
    "ASAAS_API_KEY": {
      "label": "API Key Asaas",
      "description": "Chave de API do Asaas para pagamentos PIX",
      "required": false,
      "type": "password"
    },
    "ASAAS_SANDBOX": {
      "label": "Asaas Sandbox",
      "description": "Usar ambiente sandbox do Asaas (true/false)",
      "required": false,
      "value": "true"
    }
  },
  "services": {
    "postgres": {
      "type": "postgresql",
      "version": "16",
      "volumes": ["postgres_data"]
    },
    "redis": {
      "type": "redis",
      "version": "7"
    },
    "api": {
      "type": "docker",
      "image": "ghcr.io/cezaralfredo/plataforma-agendamento-api:latest",
      "ports": ["3000"]
    },
    "web": {
      "type": "docker",
      "image": "ghcr.io/cezaralfredo/plataforma-agendamento-web:latest",
      "ports": ["80"]
    }
  }
}
