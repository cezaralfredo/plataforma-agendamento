# === BANCO DE DADOS ===
DATABASE_URL="postgresql://agendamento:SUA_SENHA_AQUI@postgres:5432/plataforma_agendamento"

# === JWT ===
# ATENÇÃO: Gere uma chave forte com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="troque-por-uma-chave-segura-aqui"
JWT_EXPIRES_IN="7d"

# === MULTI-TENANCY ===
DEFAULT_TENANT_SLUG="demo"
DISABLE_TENANT_CREATION="false"

# === EVOLUTION GO (WHATSAPP API) ===
EVOLUTION_API_URL="http://evolution:8080"
EVOLUTION_API_KEY="evo-api-key-agendamento"
EVOLUTION_INSTANCE_NAME="agendamento-bot"
EVOLUTION_WEBHOOK_URL="http://api:3000/webhook/whatsapp/${DEFAULT_TENANT_SLUG}"

# === WHATSAPP ADMIN ===
WHATSAPP_ADMIN_NUMBER="5511999999999"

# === ASAAS (PAGAMENTOS PIX) ===
ASAAS_API_KEY=""
ASAAS_API_URL=""
ASAAS_SANDBOX="true"
ASAAS_WEBHOOK_TOKEN=""

# === REDIS (FILA DE TAREFAS) ===
REDIS_URL="redis://redis:6379"

# === SERVER ===
PORT=3000
NODE_ENV="production"
FRONTEND_URL="https://SEU_DOMINIO_AQUI"
EVOLUTION_PUBLIC_URL="https://evolution.SEU_DOMINIO_AQUI"
WEB_PORT=80
EVOLUTION_PORT=8080

# === SIGNUP (SEGURANÇA) ===
# Chave secreta necessária para criar novos tenants.
SIGNUP_SECRET_KEY=""
# Desabilita completamente a criação de novas contas
DISABLE_SIGNUP="false"

# === DOCKER COMPOSE PROD ===
DOMAIN="SEU_DOMINIO_AQUI"
POSTGRES_PASSWORD="SUA_SENHA_AQUI"
EVOLUTION_POSTGRES_PASSWORD="evolution123"
IMAGE_REPOSITORY="cezaralfredo/plataforma_agendamento"
IMAGE_TAG="latest"

# === HORÁRIOS ===
TEMPO_BLOQUEIO_PROVISORIO_MINUTOS=15
TEMPO_EXPIRACAO_PIX_MINUTOS=15
HORAS_ANTECEDENCIA_CANCELAMENTO=2
PRAZO_EXPIRACAO_CREDITO_DIAS=365
